{
	"name": "lynnix",
	"version": "0.0.1",
	"description": "File-based hypermedia routing middleware for Node.js and HTMX",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/types.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build"
	},
	"repository": "https://github.com/allaboutjs/lynnix",
	"author": "Onah Victor",
	"license": "MIT",
	"private": false,
	"type": "module",
	"dependencies": {
		"mutorjs": "^3.0.2"
	},
	"peerDependencies": {
		"@fastify/busboy": "^3.2.0",
		"body-parser": "^2.3.0",
		"cookie": "^1.1.1",
		"qs": "^6.15.2"
	},
	"peerDependenciesMeta": {
		"@fastify/busboy": {
			"optional": true
		},
		"body-parser": {
			"optional": true
		},
		"cookie": {
			"optional": true
		},
		"qs": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/body-parser": "^1.19.6",
		"@types/node": "^25.9.3",
		"@types/qs": "^6.15.1",
		"tsx": "^4.22.4"
	},
	"allowScripts": {
		"esbuild@0.28.1": true
	},
	"keywords": [
		"htmx",
		"hypermedia",
		"routing",
		"ssr",
		"file-based",
		"mutor",
		"node"
	]
}
